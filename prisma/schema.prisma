generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            Int         @id @default(autoincrement())
  name          String
  description   String?
  price         Float
  stock         Int?
  imageUrl      String?     @map("image_url")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("products")
}

model User {
  id            Int         @id @default(autoincrement())
  email         String      @unique
  password      String
  role          String      @default("USER")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("users")
}